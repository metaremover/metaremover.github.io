---
interface Props {
  title?: string;
  description?: string;
  accept?: string;
}

const {
  title = 'Remove metadata from an image',
  description = 'Works with JPG, PNG, and WebP files. Your image stays on your device.',
  accept = 'image/jpeg,image/png,image/webp',
} = Astro.props;
---

<section class="tool-shell" data-metadata-remover data-accept={accept}>
  <div class="tool-panel">
    <p class="tool-label">Free browser tool</p>
    <h2>{title}</h2>
    <p class="tool-copy">{description}</p>

    <div class="dropzone" data-dropzone>
      <input class="sr-only" type="file" accept={accept} data-file-input />
      <button class="button button-primary" type="button" data-picker>Choose image</button>
      <p>or drag and drop a file here</p>
      <small>Supported: JPG, PNG, WebP</small>
    </div>

    <div class="tool-actions">
      <button class="button button-dark" type="button" disabled data-clean>
        Remove metadata
      </button>
      <a class="button button-secondary is-hidden" href="#" download data-download>
        Download cleaned image
      </a>
    </div>

    <p class="status" data-status>No file selected yet.</p>
  </div>

  <div class="tool-insights">
    <div class="preview-card">
      <p class="tool-label">Preview</p>
      <img class="preview-image is-hidden" alt="Selected image preview" data-preview />
      <div class="preview-placeholder" data-preview-placeholder>
        The selected image preview appears here.
      </div>
    </div>

    <div class="metadata-card">
      <div class="metadata-heading">
        <div>
          <p class="tool-label">Detected fields</p>
          <h3>What we can read before cleanup</h3>
        </div>
        <span class="metadata-badge" data-file-type>Waiting for file</span>
      </div>
      <ul class="metadata-list" data-meta-list>
        <li>No metadata has been scanned yet.</li>
      </ul>
    </div>
  </div>
</section>

<script>
  import exifr from 'exifr';

  const formatBytes = (bytes) => {
    if (!bytes && bytes !== 0) return '';
    const units = ['B', 'KB', 'MB', 'GB'];
    let size = bytes;
    let unitIndex = 0;

    while (size >= 1024 && unitIndex < units.length - 1) {
      size /= 1024;
      unitIndex += 1;
    }

    return `${size.toFixed(size >= 10 || unitIndex === 0 ? 0 : 1)} ${units[unitIndex]}`;
  };

  const normaliseValue = (value) => {
    if (value === null || value === undefined || value === '') return null;
    if (Array.isArray(value)) return value.join(', ');
    if (value instanceof Date) return value.toISOString();
    if (typeof value === 'object') return JSON.stringify(value);
    return String(value);
  };

  const readMetadataEntries = async (file) => {
    try {
      const data = await exifr.parse(file);

      if (!data) return [];

      return Object.entries(data)
        .map(([key, value]) => [key, normaliseValue(value)])
        .filter(([, value]) => Boolean(value))
        .slice(0, 12);
    } catch {
      return [];
    }
  };

  const loadImageElement = (file) =>
    new Promise((resolve, reject) => {
      const image = new Image();
      const objectUrl = URL.createObjectURL(file);

      image.onload = () => {
        URL.revokeObjectURL(objectUrl);
        resolve(image);
      };

      image.onerror = () => {
        URL.revokeObjectURL(objectUrl);
        reject(new Error('Image could not be loaded.'));
      };

      image.src = objectUrl;
    });

  const exportCleanBlob = async (file) => {
    const image = await loadImageElement(file);
    const canvas = document.createElement('canvas');
    canvas.width = image.naturalWidth;
    canvas.height = image.naturalHeight;

    const context = canvas.getContext('2d');

    if (!context) {
      throw new Error('Canvas is not available in this browser.');
    }

    context.drawImage(image, 0, 0);

    const outputType = file.type === 'image/png'
      ? 'image/png'
      : file.type === 'image/webp'
        ? 'image/webp'
        : 'image/jpeg';

    return new Promise((resolve, reject) => {
      canvas.toBlob(
        (blob) => {
          if (!blob) {
            reject(new Error('Failed to create the cleaned image.'));
            return;
          }

          resolve(blob);
        },
        outputType,
        0.94,
      );
    });
  };

  const buildDownloadName = (file) => {
    const parts = file.name.split('.');
    const extension = parts.length > 1 ? parts.pop() : 'jpg';
    const baseName = parts.join('.') || 'image';
    return `${baseName}-clean.${extension}`;
  };

  document.querySelectorAll('[data-metadata-remover]').forEach((root) => {
    if (root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const input = root.querySelector('[data-file-input]');
    const picker = root.querySelector('[data-picker]');
    const dropzone = root.querySelector('[data-dropzone]');
    const cleanButton = root.querySelector('[data-clean]');
    const download = root.querySelector('[data-download]');
    const status = root.querySelector('[data-status]');
    const preview = root.querySelector('[data-preview]');
    const previewPlaceholder = root.querySelector('[data-preview-placeholder]');
    const metaList = root.querySelector('[data-meta-list]');
    const fileType = root.querySelector('[data-file-type]');

    let currentFile = null;
    let currentPreviewUrl = null;
    let currentDownloadUrl = null;

    const setStatus = (message) => {
      status.textContent = message;
    };

    const resetDownload = () => {
      if (currentDownloadUrl) {
        URL.revokeObjectURL(currentDownloadUrl);
        currentDownloadUrl = null;
      }

      download.classList.add('is-hidden');
      download.removeAttribute('href');
      download.removeAttribute('download');
    };

    const renderMetadata = (entries) => {
      metaList.innerHTML = '';

      if (!entries.length) {
        const item = document.createElement('li');
        item.textContent = 'No readable EXIF fields were found. The cleaned export still creates a fresh file.';
        metaList.append(item);
        return;
      }

      entries.forEach(([key, value]) => {
        const item = document.createElement('li');
        const label = document.createElement('strong');
        label.textContent = `${key}: `;
        item.append(label, document.createTextNode(value));
        metaList.append(item);
      });
    };

    const showPreview = (file) => {
      if (currentPreviewUrl) {
        URL.revokeObjectURL(currentPreviewUrl);
      }

      currentPreviewUrl = URL.createObjectURL(file);
      preview.src = currentPreviewUrl;
      preview.classList.remove('is-hidden');
      previewPlaceholder.classList.add('is-hidden');
    };

    const loadFile = async (file) => {
      currentFile = file;
      cleanButton.disabled = false;
      resetDownload();
      showPreview(file);
      fileType.textContent = `${file.type.replace('image/', '').toUpperCase()} • ${formatBytes(file.size)}`;
      setStatus(`Scanning ${file.name} for readable metadata...`);

      const entries = await readMetadataEntries(file);
      renderMetadata(entries);
      setStatus(`Ready to remove metadata from ${file.name}.`);
    };

    picker.addEventListener('click', () => input.click());
    input.addEventListener('change', async (event) => {
      const [file] = event.target.files ?? [];
      if (file) await loadFile(file);
    });

    ['dragenter', 'dragover'].forEach((eventName) => {
      dropzone.addEventListener(eventName, (event) => {
        event.preventDefault();
        dropzone.classList.add('is-active');
      });
    });

    ['dragleave', 'drop'].forEach((eventName) => {
      dropzone.addEventListener(eventName, (event) => {
        event.preventDefault();
        dropzone.classList.remove('is-active');
      });
    });

    dropzone.addEventListener('drop', async (event) => {
      const [file] = event.dataTransfer?.files ?? [];
      if (file) await loadFile(file);
    });

    cleanButton.addEventListener('click', async () => {
      if (!currentFile) return;

      cleanButton.disabled = true;
      setStatus(`Creating a cleaned copy of ${currentFile.name}...`);

      try {
        const blob = await exportCleanBlob(currentFile);
        resetDownload();
        currentDownloadUrl = URL.createObjectURL(blob);
        download.href = currentDownloadUrl;
        download.download = buildDownloadName(currentFile);
        download.classList.remove('is-hidden');
        setStatus(
          `Clean image ready. Original: ${formatBytes(currentFile.size)}. New file: ${formatBytes(blob.size)}.`,
        );
      } catch (error) {
        setStatus(error instanceof Error ? error.message : 'Something went wrong while cleaning the image.');
      } finally {
        cleanButton.disabled = false;
      }
    });
  });
</script>
