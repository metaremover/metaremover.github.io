---
interface LinkItem {
  href: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  intro: string;
  links?: LinkItem[];
}

const { eyebrow, title, intro, links = [] } = Astro.props;
---

<section class="page-hero container">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1>{title}</h1>
  <p class="hero-intro">{intro}</p>
  {links.length > 0 && (
    <div class="inline-links">
      {links.map((link) => (
        <a class="pill-link" href={link.href}>{link.label}</a>
      ))}
    </div>
  )}
</section>
